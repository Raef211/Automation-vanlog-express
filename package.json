{
  "name": "automatisation-pom",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "cucumber-js --config cucumber.js",
    "test:headless": "cross-env HEADLESS=true cucumber-js --config cucumber.js",
    "test:headed": "cross-env HEADLESS=false SLOWMO_MS=100 cucumber-js --config cucumber.js",
    "test:e2e": "cross-env HEADLESS=true cucumber-js --config cucumber-e2e.js --tags \"@e2e\"",
    "test:e2e:headed": "cross-env HEADLESS=false SLOWMO_MS=100 cucumber-js --config cucumber-e2e.js --tags \"@e2e\"",
    "test:e2e:client": "cross-env HEADLESS=true cucumber-js --config cucumber-e2e.js --tags \"@client-signup or @client-login\"",
    "test:e2e:client:headed": "cross-env HEADLESS=false SLOWMO_MS=100 cucumber-js --config cucumber-e2e.js --tags \"@client-signup\"",
    "test:e2e:admin": "cross-env HEADLESS=true cucumber-js --config cucumber-e2e.js --tags \"@admin-approval or @admin-dashboard\"",
    "test:e2e:admin:headed": "cross-env HEADLESS=false SLOWMO_MS=100 cucumber-js --config cucumber-e2e.js --tags \"@admin-approval\"",
    "test:e2e:delivery": "cross-env HEADLESS=true cucumber-js --config cucumber-e2e.js --tags \"@delivery-creation\"",
    "test:e2e:complete": "cross-env HEADLESS=false SLOWMO_MS=100 cucumber-js --config cucumber-e2e.js --tags \"@complete-workflow\"",
    "test:ui": "cucumber-js --config cucumber.js --tags \"not @api\"",
    "test:pw:admin": "npx playwright test e2e/tests/admin.spec.js --project=chromium",
    "test:postman:newman": "cross-env NEWMAN_BASE_URL=http://localhost:3000 newman run postman/TUNLOG_full_postman_collection.json -e postman/local.postman_environment.json -r cli,json,htmlextra --reporter-json-export reports/postman/newman-results.json --reporter-htmlextra-export reports/postman/newman-report.html",
    "test:postman:newman:verbose": "cross-env NEWMAN_BASE_URL=http://localhost:3000 newman run postman/TUNLOG_full_postman_collection.json -e postman/local.postman_environment.json -r cli,json,htmlextra --reporter-json-export reports/postman/newman-results.json --reporter-htmlextra-export reports/postman/newman-report.html --verbose",
    "test:newman:e2e": "cross-env NEWMAN_BASE_URL=http://localhost:3000 newman run newman/collections/e2e-processus-livraison.postman_collection.json -e newman/environments/local.postman_environment.json -r cli,json,htmlextra --reporter-json-export reports/newman/e2e-processus-livraison.json --reporter-htmlextra-export reports/newman/e2e-processus-livraison.html",
    "test:newman:e2e:detailed": "npm run test:newman:e2e && node scripts/newman-detailed-report.js reports/newman/e2e-processus-livraison.json reports/newman/e2e-processus-livraison-detailed.md",
    "generate:postman": "node scripts/generate_postman_from_openapi.js",
    "test:postman": "node scripts/test-postman-collection.js",
    "test:postman:full": "node scripts/test-postman-collection-full.js",
    "test:postman:auth": "node scripts/test-postman-with-auth.js",
    "test:postman:token": "node scripts/test-with-token.js",
    "test:dashboard": "node scripts/generate-html-dashboard.js",
    "test:postman:complete": "npm run test:postman:auth && npm run test:dashboard",
    "test:postman:complete:token": "npm run test:postman:token && npm run test:dashboard",
    "test:summary": "node scripts/generate-test-summary.js",
    "test:postman:windows": "powershell -ExecutionPolicy Bypass -File scripts/test-postman.ps1",
    "test:all": "node scripts/run-all-tests-with-newman.js",
    "test:all:verbose": "cross-env VERBOSE=true node scripts/run-all-tests-with-newman.js",
    "test:reports:open": "node scripts/open-reports.js",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@playwright/test": "^1.58.2",
    "allure-commandline": "^2.41.0",
    "allure-cucumberjs": "^3.9.0",
    "cross-env": "^7.0.3",
    "newman": "^6.2.2",
    "newman-reporter-htmlextra": "^1.23.1",
    "node-fetch": "^2.6.7",
    "openapi-to-postmanv2": "^1.0.23"
  }
}
