# Configuration Docker pour tests Playwright

# Mode headless (true/false)
HEADLESS=true

# URL de base pour les tests
BASE_URL=http://localhost:3000

# Variables Playwright
PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=false

# Niveau de log (verbose, info, debug)
LOG_LEVEL=info

# Timeout pour les tests (ms)
TIMEOUT=30000

# Nombre de workers Cucumber
PARALLEL_WORKERS=4

# Variable pour Newman/Postman
NEWMAN_BASE_URL=http://localhost:3000
