const { chromium } = require('@playwright/test');

(async () => {
  const browser = await chromium.launch({ headless: false, slowMo: 80 });
  const context = await browser.newContext({ viewport: { width: 1920, height: 1080 } });
  const page = await context.newPage();

  await page.goto('http://localhost:3000/login');
  await page.waitForLoadState('networkidle');

  await page.fill('#loginEmail', 'support@vanlog-express.com');
  await page.fill('#password', 'y8JzyLZ5Utcw7Q+n(CnQ');
  await page.click('button[type="submit"]');
  await page.waitForLoadState('networkidle');
  await page.waitForTimeout(1500);

  const facturesMenu = page.locator('.ant-menu-item').filter({ hasText: 'Factures' }).first();
  await facturesMenu.click();
  await page.waitForLoadState('networkidle');
  await page.waitForTimeout(1000);

  const selectUserBtn = page.locator('button').filter({ hasText: /Select User|sélectionner|utilisateur/i }).first();
  await selectUserBtn.click({ force: true });
  await page.waitForTimeout(1200);

  const inspection = await page.evaluate(() => {
    const normalize = value => (value || '').toLowerCase();
    const visible = element => {
      if (!element) return false;
      const style = window.getComputedStyle(element);
      const rect = element.getBoundingClientRect();
      return style.visibility !== 'hidden' && style.display !== 'none' && rect.width > 0 && rect.height > 0;
    };

    const dropdownContainers = Array.from(document.querySelectorAll('.ant-select-dropdown, .ant-dropdown, [role="listbox"], .ant-popover, .ant-modal, .ant-drawer'))
      .filter(visible)
      .map((el, idx) => ({
        idx,
        className: el.className,
        role: el.getAttribute('role') || '',
        textSnippet: (el.textContent || '').trim().slice(0, 400)
      }));

    const optionCandidates = Array.from(document.querySelectorAll('.ant-select-item-option-content, [role="option"], .ant-dropdown-menu-title-content, li, button, span'))
      .filter(el => visible(el) && (el.textContent || '').trim().length > 0)
      .map(el => (el.textContent || '').trim())
      .filter((text, index, arr) => arr.indexOf(text) === index)
      .slice(0, 200);

    const matched = optionCandidates.filter(text => /client|provider|entreprise|livreur|transporteur|carrier|driver/i.test(normalize(text)));

    return {
      url: window.location.href,
      title: document.title,
      dropdownContainers,
      optionCandidates,
      matched,
      pageButtons: Array.from(document.querySelectorAll('button')).map(btn => (btn.textContent || '').trim()).filter(Boolean)
    };
  });

  console.log(JSON.stringify(inspection, null, 2));

  await page.screenshot({ path: 'screenshots/invoice-select-user-open.png', fullPage: true });
  await browser.close();
})();
