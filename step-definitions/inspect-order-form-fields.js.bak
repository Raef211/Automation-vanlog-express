const { chromium } = require('@playwright/test');

(async () => {
  const browser = await chromium.launch({ headless: true });
  const context = await browser.newContext();
  const page = await context.newPage();

  try {
    console.log('Connexion et accès formulaire...');
    await page.goto('http://localhost:3000/login', { waitUntil: 'domcontentloaded' });
    await page.fill('#loginEmail', 'client@gmail.com');
    await page.fill('#password', '123456789');
    await page.click('button[type="submit"]');
    await page.waitForTimeout(2500);

    // Aller à la liste des commandes
    const ordersMenu = page.locator('.ant-menu-item').filter({ hasText: 'Liste des commandes' }).first();
    if (await ordersMenu.count()) {
      await ordersMenu.click();
    } else {
      await page.goto('http://localhost:3000/admin/orders', { waitUntil: 'domcontentloaded' });
    }

    await page.waitForTimeout(1000);

    // Ouvrir le formulaire "Livrer une commande"
    const addBtn = page.locator('button:has-text("Ajouter une commande")').first();
    if (await addBtn.count()) {
      await addBtn.click();
      await page.waitForTimeout(1200);

      const livrerBtn = page.locator('button:has-text("Livrer une commande")').first();
      if (await livrerBtn.count()) {
        await livrerBtn.click();
        await page.waitForTimeout(1500);
      }
    }

    // Inspecter le formulaire
    const formInfo = await page.evaluate(() => {
      const modal = document.querySelector('.ant-modal') || document.querySelector('.ant-drawer');
      if (!modal) return { error: 'No modal found' };

      const result = {};

      // Tous les inputs
      const allInputs = Array.from(modal.querySelectorAll('input, textarea, select'));

      result.allFields = allInputs.map((inp, idx) => ({
        idx,
        type: inp.type || inp.tagName,
        id: inp.id,
        name: inp.name,
        placeholder: inp.placeholder,
        required: inp.required || inp.getAttribute('aria-required') === 'true',
        value: inp.value || '',
        label: inp.closest('.ant-form-item')?.querySelector('label')?.textContent?.trim()
      }));

      // Tous les labels
      result.allLabels = Array.from(modal.querySelectorAll('label, .ant-form-item-label'))
        .map(l => l.textContent?.trim())
        .filter(t => t && t.length > 0 && t.length < 100);

      // Form items count
      result.formItems = modal.querySelectorAll('.ant-form-item').length;

      // Errors
      result.errors = Array.from(modal.querySelectorAll('.ant-form-item-explain-error'))
        .map(e => e.textContent?.trim());

      // Required fields
      result.requiredFields = allInputs
        .filter(inp => inp.required || inp.getAttribute('aria-required') === 'true')
        .map(inp => ({
          id: inp.id,
          placeholder: inp.placeholder,
          label: inp.closest('.ant-form-item')?.querySelector('label')?.textContent?.trim()
        }));

      return result;
    });

    console.log(JSON.stringify(formInfo, null, 2));

  } catch (err) {
    console.error('Error:', err.message);
  } finally {
    await context.close();
    await browser.close();
  }
})();
